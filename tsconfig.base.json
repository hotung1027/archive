{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@omnisearch/types": ["./packages/types/src/index.ts"],
      "@omnisearch/db":    ["./packages/db/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
